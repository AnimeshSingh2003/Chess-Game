PORT=3001

# SQLite database path (Render free tier: data is ephemeral on restart)
# For persistence, add a Render Disk and set a path like /data/archess.sqlite
DB_PATH=./archess.sqlite

# Set this in Render dashboard → Environment → after your Vercel deploy
# Value = your Vercel frontend URL, e.g. https://your-app.vercel.app
CLIENT_ORIGIN=https://your-app.vercel.app
